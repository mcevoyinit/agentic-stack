#!/usr/bin/env bash
# hermes CLI wrapper. Uses the skill's own venv so deps are consistent.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
SKILL_DIR="$( cd "$SCRIPT_DIR/.." && pwd )"
PY="$SKILL_DIR/.venv/bin/python"
if [[ ! -x "$PY" ]]; then
  echo "venv missing. bootstrap with:" >&2
  echo "  python3 -m venv $SKILL_DIR/.venv" >&2
  echo "  $SKILL_DIR/.venv/bin/pip install -r $SKILL_DIR/requirements.txt" >&2
  exit 2
fi
exec "$PY" "$SCRIPT_DIR/hermes.py" "$@"
